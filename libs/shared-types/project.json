{
  "name": "shared-types",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared-types/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "generate-runtime-scripts": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx libs/shared-types/scripts/build-runtime-scripts.ts"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["generate-runtime-scripts"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared-types",
        "main": "libs/shared-types/src/index.ts",
        "tsConfig": "libs/shared-types/tsconfig.lib.json",
        "assets": ["libs/shared-types/*.md"]
      }
    }
  }
}
