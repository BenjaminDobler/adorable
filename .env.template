ANTHROPIC_API_KEY=your_api_key_here
PORT=3333
DOCKER_SOCKET_PATH=/var/run/docker.sock
DATABASE_URL=file:./dev.db
JWT_SECRET=change-me-to-a-random-secret
ENCRYPTION_KEY=change-me-to-a-random-32-char-key

# GitHub OAuth (optional - for GitHub integration)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://your-domain.com/api/github/callback

# App URLs (optional - auto-detected from request if not set)
# CLIENT_URL=https://your-domain.com
# APP_URL=https://your-domain.com

# SMTP (optional - for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
