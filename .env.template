PORT=3333
DOCKER_SOCKET_PATH=/var/run/docker.sock
DATABASE_URL=file:./dev.db
JWT_SECRET=change-me-to-a-random-secret
ENCRYPTION_KEY=change-me-to-a-random-32-char-key

# GitHub OAuth (optional - for repo linking and social login)
# Set callback URL on GitHub to your domain root (e.g. https://your-domain.com)
# so both /api/github/callback and /api/auth/social/github/callback work.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth (optional - for Google social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/social/google/callback

# App URLs (optional - auto-detected from request if not set)
# CLIENT_URL=https://your-domain.com
# APP_URL=https://your-domain.com

# SMTP (optional - for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
