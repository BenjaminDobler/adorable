{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.adorable.desktop",
  "productName": "Adorable",
  "directories": {
    "output": "dist/desktop-release",
    "app": "dist/apps/desktop"
  },
  "files": [
    "**/*",
    "!**/*.ts",
    "!tsconfig.json",
    "!electron-builder.json"
  ],
  "npmRebuild": true,
  "asarUnpack": [
    "node_modules/**"
  ],
  "extraResources": [
    {
      "from": "dist/apps/client/browser",
      "to": "client/browser"
    },
    {
      "from": "dist/apps/server",
      "to": "server"
    },
    {
      "from": "dist/libs/shared-types",
      "to": "libs/shared-types"
    },
    {
      "from": "apps/desktop/icons",
      "to": "icons"
    }
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.developer-tools",
    "icon": "apps/desktop/icons/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "apps/desktop/entitlements.mac.plist",
    "entitlementsInherit": "apps/desktop/entitlements.mac.plist",
    "notarize": true
  },
  "win": {
    "target": ["nsis"],
    "icon": "apps/desktop/icons/icon.ico"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Development",
    "icon": "apps/desktop/icons/icon.png"
  },
  "publish": {
    "provider": "github",
    "owner": "BenjaminDobler",
    "repo": "adorable",
    "releaseType": "draft"
  }
}
